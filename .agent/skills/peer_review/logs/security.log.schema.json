{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "R&R Security Log Entry",
    "description": "Schema for security event logging in the R&R peer review system",
    "type": "object",
    "required": [
        "timestamp",
        "session_id",
        "event"
    ],
    "properties": {
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO-8601 formatted timestamp of the event"
        },
        "session_id": {
            "type": "string",
            "pattern": "^[0-9]{8}-[0-9]{6}-[a-z0-9]{4}$",
            "description": "Session ID in format YYYYMMDD-HHMMSS-xxxx"
        },
        "event": {
            "type": "string",
            "enum": [
                "validation_pass",
                "validation_fail",
                "pattern_match",
                "escalation",
                "trust_bypass"
            ],
            "description": "Type of security event"
        },
        "details": {
            "type": "object",
            "description": "Additional event-specific details",
            "properties": {
                "patterns_matched": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "List of suspicious patterns detected"
                },
                "input_size": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Word count of the input document"
                },
                "validation_error": {
                    "type": "string",
                    "description": "Validation error code if applicable"
                },
                "file_path": {
                    "type": "string",
                    "description": "Path to the document being reviewed"
                }
            }
        }
    },
    "examples": [
        {
            "timestamp": "2026-01-31T10:15:00Z",
            "session_id": "20260131-101500-a1b2",
            "event": "validation_pass",
            "details": {
                "input_size": 247,
                "patterns_matched": [],
                "file_path": "/path/to/document.md"
            }
        },
        {
            "timestamp": "2026-01-31T10:16:00Z",
            "session_id": "20260131-101600-c3d4",
            "event": "pattern_match",
            "details": {
                "patterns_matched": [
                    "ignore previous instructions"
                ],
                "input_size": 500,
                "file_path": "/path/to/suspicious.md"
            }
        }
    ]
}